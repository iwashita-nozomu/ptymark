# @dependency-start
# contract environment
# responsibility Pins canonical ptymark validation image inputs only.
# upstream environment ../rust-toolchain.toml canonical Rust version
# upstream environment ../renderers/managed-bundle.env canonical managed Node version
# downstream environment ./ptymark-compose.yaml product container build args
# downstream tool ../scripts/check-ptymark-runtime-dependencies.mjs version alignment gate
# @dependency-end

# Renderer package versions belong in renderers/managed-bundle.env and package-lock.json.
NODE_IMAGE=node:24.18.0-bookworm
RUST_VERSION=1.97.0
PTYMARK_IMAGE_TAG=local
