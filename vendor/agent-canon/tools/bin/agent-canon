#!/usr/bin/env bash
# @dependency-start
# contract tool
# responsibility Provides stable shell entrypoint for the AgentCanon Rust CLI.
# upstream design ../../documents/rust-agent-tool-migration.md Rust tool migration policy
# upstream implementation ../../rust/agent-canon/src/main.rs Rust CLI entrypoint
# @dependency-end

set -euo pipefail

script_path="${BASH_SOURCE[0]}"
if command -v readlink >/dev/null 2>&1; then
  script_path="$(readlink -f "$script_path")"
fi
canon_root="$(cd "$(dirname "$script_path")/../.." && pwd)"
manifest="${canon_root}/rust/agent-canon/Cargo.toml"
tools_home="${AGENT_CANON_TOOLS_HOME:-${HOME}/.tools}"
installed_binary="${tools_home}/agent-canon/bin/agent-canon"
legacy_binary="/opt/agent-canon/bin/agent-canon"

if ! command -v cargo >/dev/null 2>&1 && [ -f "${HOME}/.cargo/env" ]; then
  # shellcheck disable=SC1091
  . "${HOME}/.cargo/env"
fi

if [ ! -x "$installed_binary" ] && [ -x "$legacy_binary" ]; then
  installed_binary="$legacy_binary"
fi

if [ "${1:-}" = "local-llm" ] && command -v cargo >/dev/null 2>&1; then
  exec cargo run --manifest-path "$manifest" -- "$@"
fi

if [ -x "$installed_binary" ]; then
  source_newer=""
  if [ -d "${canon_root}/rust/agent-canon/src" ] && command -v find >/dev/null 2>&1; then
    source_newer="$(
      find "${canon_root}/rust/agent-canon" \
        \( -name '*.rs' -o -name 'Cargo.toml' \) \
        -newer "$installed_binary" \
        -print -quit
    )"
  fi
  if [ -z "$source_newer" ]; then
    exec "$installed_binary" "$@"
  fi
fi

if command -v cargo >/dev/null 2>&1; then
  exec cargo run --manifest-path "$manifest" -- "$@"
fi

if [ -x "$installed_binary" ]; then
  exec "$installed_binary" "$@"
fi

echo "agent-canon runtime is unavailable" >&2
exit 1
