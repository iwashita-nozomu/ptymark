{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/hook_dispatcher.py\" UserPromptSubmit",
            "timeout": 40,
            "statusMessage": "Running prompt guard suite"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|python|python3",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/hook_dispatcher.py\" PreToolUse",
            "timeout": 35,
            "statusMessage": "Running pre-tool guard suite"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|python|python3|Task|spawn_agent|send_input|wait_agent|close_agent|resume_agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/hook_dispatcher.py\" PostToolUse",
            "timeout": 600,
            "statusMessage": "Running post-tool guard suite"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/hook_dispatcher.py\" Stop",
            "timeout": 600,
            "statusMessage": "Running stop guard suite"
          }
        ]
      }
    ]
  }
}
