{
  "_dependency_manifest": [
    "@dependency-start",
    "contract reference",
    "responsibility Configures shared VS Code workspace defaults for AgentCanon and template roots.",
    "upstream design ../documents/SHARED_RUNTIME_SURFACES.md shared runtime surface policy",
    "upstream design ../documents/github-first-module-and-devcontainer-policy.md VS Code and devcontainer boundary policy",
    "upstream design ../responsibility-scope.toml runtime-entrypoints ownership scope",
    "@dependency-end"
  ],
  "files.associations": {
    "*.cu": "cuda-cpp",
    "*.cuh": "cuda-cpp",
    "*.h": "cpp",
    "*.hpp": "cpp"
  },
  "files.exclude": {
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/__pycache__": true,
    "build": true,
    "logs": true
  },
  "search.exclude": {
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/__pycache__": true,
    "build": true,
    "logs": true
  },
  "explorer.excludeGitIgnore": false,
  "python.analysis.extraPaths": [
    "./python",
    "./src",
    "./tools"
  ],
  "python-envs.defaultEnvManager": "ms-python.python:system",
  "python-envs.pythonProjects": [],
  "python.envFile": "${workspaceFolder}/.env",
  "jupyter.notebookFileRoot": "${workspaceFolder}"
}
